      "timeout": 60,
      "disabled": false
    },
    "supabase-server": {
      "command": "npx",
      "args": [
        "-y",
        "@supabase/mcp-server-supabase@latest",
        "--project-ref",
        "fnrlzhrchuoiwwsugidz"
      ],
      "transportType": "stdio",
      "timeout": 60,
