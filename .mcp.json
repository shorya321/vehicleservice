      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ],
      "transportType": "stdio",
      "timeout": 60,
      "autoApprove": [
        "sequentialthinking"
      ],
      "disabled": false
    },
    "linear": {
      "command": "npx",
      "args": [
        "-y",
        "mcp-remote",
